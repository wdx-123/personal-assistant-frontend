  "components": {
    "schemas": {
      "ApiItem": {
        "type": "object",
        "description": "API 详情对象（列表项与详情共用）",
        "properties": {
          "id": {
            "type": "integer",
            "description": "API ID"
          },
          "path": {
            "type": "string",
            "description": "API 路径"
          },
          "method": {
            "type": "string",
            "description": "HTTP 请求方法",
            "enum": [
              "GET",
              "POST",
              "PUT",
              "DELETE",
              "PATCH"
            ]
          },
          "detail": {
            "type": "string",
            "description": "API 描述"
          },
          "status": {
            "type": "integer",
            "description": "状态：1 启用，0 禁用",
            "enum": [
              0,
              1
            ]
          },
          "menu_id": {
            "type": "integer",
            "description": "归属菜单 ID；未绑定时为 null",
